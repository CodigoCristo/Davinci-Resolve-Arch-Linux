#!/bin/bash

# ====================================================================
# VGet Descargador de Videos - Basado en yt-dlp
# hay otro para descargar fotos llamado https://github.com/mikf/gallery-dl
# ====================================================================

set -euo pipefail

# Colores
R='\033[0;31m'
G='\033[0;32m'
Y='\033[1;33m'
B='\033[0;34m'
C='\033[0;36m'
M='\033[0;35m'
W='\033[1;37m'
DIM='\033[2m'
NC='\033[0m'

linea() { echo -e "${DIM}${B}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"; }
ok()    { echo -e "${G}✔  $1${NC}"; }
info()  { echo -e "${C}ℹ  $1${NC}"; }
warn()  { echo -e "${Y}⚠  $1${NC}"; }
err()   { echo -e "${R}✘  $1${NC}"; }

# Lista de archivos descargados en Instagram (para convert_video)
_DL_FILES=()

# Caja: ancho interior = 64 (total visible = 66 con bordes)
_BI=64
box_top() { printf "${B}┏"; printf '━%.0s' {1..64}; printf "┓${NC}\n"; }
box_bot() { printf "${B}┗"; printf '━%.0s' {1..64}; printf "┛${NC}\n"; }
box_sep() { printf "${B}┣"; printf '━%.0s' {1..64}; printf "┫${NC}\n"; }
# brow <texto_plano> <texto_coloreado> [ajuste_ancho_extra]
brow() {
    local plain="$1" colored="${2:-$1}" xtra="${3:-0}"
    local pad=$(( _BI - ${#plain} - xtra - 2 ))
    local spaces; spaces=$(printf '%*s' "$pad" '')
    echo -e "${B}┃${NC} ${colored}${spaces} ${B}┃${NC}"
}

menu_principal() {
    clear
    box_top
    brow "  VGet Descargador de Videos  " "  ${W}VGet Descargador de Videos${NC}  "
    brow "  Basado en yt-dlp            " "  ${DIM}Basado en yt-dlp${NC}            "
    box_sep
    brow "  1. ▶  YouTube"   "  ${W}1.${NC} ${R}▶${NC}  YouTube"
    brow "  2. ♪  TikTok"    "  ${W}2.${NC} ${W}♪${NC}  TikTok"
    brow "  3. f  Facebook"  "  ${W}3.${NC} ${B}f${NC}  Facebook"
    brow "  4.    Instagram" "  ${W}4.${NC} ${M}📷${NC}  Instagram" 1
    brow "  5. ✖  Salir"     "  ${W}5.${NC} ${R}✖${NC}  Salir"
    box_bot
    echo -ne "${Y}  ➜  Selecciona una opcion (1-5): ${NC}"
    read -r opcion

    case "$opcion" in
        1) descargar_youtube ;;
        2) descargar "TikTok"    "${W}♪  TikTok${NC}"    ;;
        3) descargar_facebook ;;
        4) descargar_instagram ;;
        5) salir ;;
        *) menu_principal ;;
    esac
}

# ====================================================================
# YouTube — descarga avanzada con selección de resolución y codec
# ====================================================================
descargar_youtube() {
    clear
    linea
    echo -e "  ${R}▶${NC}  ${W}YouTube${NC} — Seleccion de calidad"
    linea
    echo
    echo -ne "${Y}  🔗  Pega la URL del video: ${NC}"
    read -r url

    if [[ -z "$url" ]]; then
        err "No has ingresado ninguna URL"
        echo -ne "${DIM}  Presiona Enter...${NC}"; read -r
        menu_principal; return
    fi

    # Extraer solo ?v=ID, eliminar &list= &index= y otros parametros
    if [[ "$url" == *"v="* ]]; then
        local vid="${url#*v=}"
        vid="${vid%%&*}"
        vid="${vid%%\?*}"
        vid="${vid%%\#*}"
        url="https://www.youtube.com/watch?v=${vid}"
    else
        url="${url%%\#*}"
    fi
    echo
    info "Obteniendo formatos disponibles..."
    linea

    local tmp; tmp=$(mktemp /tmp/vget_yt.XXXXXX)
    yt-dlp -F "$url" 2>&1 | tee "$tmp"

    # Etiquetas por altura de resolución
    declare -A res_names=(
        [4320]="8K   (4320p)"
        [2160]="4K   (2160p)"
        [1440]="2K   (1440p)"
        [1080]="1080p"
        [720]="720p"
        [480]="480p"
        [360]="360p"
        [240]="240p"
        [144]="144p"
    )

    # Parsear líneas mp4_dash video-only
    # (sin depender del separador │ vs | según terminal)
    declare -a heights_order=()
    declare -A heights_seen=()
    declare -A height_fmts=()

    while IFS= read -r line; do
        [[ "$line" != *"mp4_dash"* ]] && [[ "$line" != *"webm_dash"* ]] && continue
        [[ "$line" != *"video only"* ]] && continue

        local fmt_id resolution fps height codec_key codec_label container

        fmt_id=$(awk '{print $1}' <<< "$line")
        [[ -z "$fmt_id" ]] && continue

        # Resolución: primer patrón NxM de la línea
        resolution=$(grep -oP '\d+x\d+' <<< "$line" | head -1 || true)
        [[ -z "$resolution" ]] && continue

        # FPS: campo inmediatamente después de la resolución
        fps=$(awk -v r="$resolution" '{for(i=1;i<=NF;i++) if($i==r){print $(i+1); exit}}' <<< "$line")

        height="${resolution#*x}"
        [[ -z "$height" ]] && continue
        [[ -z "${res_names[$height]+x}" ]] && continue

        # Codec: avc1 / av01 (mp4_dash)  o  vp9 / vp9.2 (webm_dash)
        local codec_key codec_label container
        if grep -qP '\bavc1\.' <<< "$line"; then
            codec_key="h264"; codec_label="H.264 (AVC) SDR"; container="mp4"
        elif grep -qP '\bav01\.' <<< "$line"; then
            if [[ "$line" == *"HDR"* ]]; then
                codec_key="av1_hdr"; codec_label="AV1 HDR (10-bit)"
            else
                codec_key="av1_sdr"; codec_label="AV1 SDR"
            fi
            container="mp4"
        elif grep -qP '\bvp9\.2\b' <<< "$line"; then
            codec_key="vp9_hdr"; codec_label="VP9 HDR (10-bit)"; container="mkv"
        elif grep -qP '\bvp9\b' <<< "$line"; then
            codec_key="vp9"; codec_label="VP9 SDR"; container="mkv"
        else
            continue
        fi

        if [[ -z "${heights_seen[$height]+x}" ]]; then
            heights_order+=("$height")
            heights_seen[$height]=1
            height_fmts[$height]=""
        fi
        height_fmts[$height]+="${fmt_id}|${fps}|${codec_label}|${codec_key}|${container}"$'\n'
    done < "$tmp"
    rm -f "$tmp"

    # Ordenar resoluciones descendente (mayor calidad primero)
    mapfile -t heights_order < <(printf '%s\n' "${heights_order[@]}" | sort -rn)

    if [[ ${#heights_order[@]} -eq 0 ]]; then
        echo; err "No se encontraron formatos mp4_dash disponibles"
        echo -ne "${DIM}  Presiona Enter...${NC}"; read -r
        menu_principal; return
    fi

    # ── Menú de formatos ────────────────────────────────────────────
    echo
    linea
    echo -e "${W}  Formatos disponibles:${NC}"
    linea

    local i=1
    for h in "${heights_order[@]}"; do
        local icono="${G}●${NC}"
        (( h >= 2160 )) && icono="${M}★${NC}"
        (( h >= 4320 )) && icono="${Y}★${NC}"
        echo -e "  ${W}${i}.${NC} ${icono}  ${res_names[$h]}"
        ((i++))
    done
    local i_mp3=$i; ((i++))
    local i_wav=$i; ((i++))
    local i_cancel=$i
    echo -e "  ${W}${i_mp3}.${NC} ${M}♪${NC}  MP3 — audio only  ${DIM}16bit / 44.1kHz${NC}"
    echo -e "  ${W}${i_wav}.${NC} ${C}♪${NC}  WAV — audio only  ${DIM}24bit / 48kHz${NC}"
    echo -e "  ${W}${i_cancel}.${NC} ${R}✖${NC}  Cancelar"
    linea
    while true; do
        echo -ne "${Y}  ➜  Opcion: ${NC}"
        read -r res_choice

        if [[ "$res_choice" == "$i_cancel" ]] || [[ -z "$res_choice" ]]; then
            menu_principal; return
        fi

        # Opcion MP3
        if [[ "$res_choice" == "$i_mp3" ]]; then
            echo; linea
            info "Descargando audio 140 (m4a) y convirtiendo a MP3..."
            linea
            if yt-dlp -f 140 --restrict-filenames --output "%(title).50s.m4a" "$url"; then
                local m4a_file; m4a_file=$(ls -t ./*.m4a 2>/dev/null | head -n1 || true)
                if [[ -n "$m4a_file" ]]; then
                    local mp3_file="${m4a_file%.m4a}.mp3"
                    if ffmpeg -i "$m4a_file" -c:a libmp3lame -ar 44100 -sample_fmt s16p -y "$mp3_file"; then
                        rm -f "$m4a_file"
                        echo; ok "Guardado: ${W}$mp3_file${NC} ✅"
                    else
                        err "Error convirtiendo a MP3"
                    fi
                fi
            else
                err "Error descargando audio"
            fi
            linea
            echo -ne "${DIM}  Presiona Enter...${NC}"; read -r
            menu_principal; return
        fi

        # Opcion WAV
        if [[ "$res_choice" == "$i_wav" ]]; then
            echo; linea
            info "Descargando audio 140 (m4a) y convirtiendo a WAV..."
            linea
            if yt-dlp -f 140 --restrict-filenames --output "%(title).50s.m4a" "$url"; then
                local m4a_file; m4a_file=$(ls -t ./*.m4a 2>/dev/null | head -n1 || true)
                if [[ -n "$m4a_file" ]]; then
                    local wav_file="${m4a_file%.m4a}.wav"
                    if ffmpeg -i "$m4a_file" -c:a pcm_s24le -ar 48000 -y "$wav_file"; then
                        rm -f "$m4a_file"
                        echo; ok "Guardado: ${W}$wav_file${NC} ✅"
                    else
                        err "Error convirtiendo a WAV"
                    fi
                fi
            else
                err "Error descargando audio"
            fi
            linea
            echo -ne "${DIM}  Presiona Enter...${NC}"; read -r
            menu_principal; return
        fi

        if ! [[ "$res_choice" =~ ^[0-9]+$ ]] || (( res_choice < 1 || res_choice >= i_mp3 )); then
            warn "Opcion invalida"
            continue
        fi

        break
    done

    local sel_height="${heights_order[$((res_choice - 1))]}"

    # Parsear variantes para la resolución elegida
    mapfile -t fmt_lines < <(printf '%s' "${height_fmts[$sel_height]}" | grep -v '^$')

    # ── Menú de codec / fps ─────────────────────────────────────────
    echo
    linea
    echo -e "${W}  ${res_names[$sel_height]} — Selecciona variante:${NC}"
    linea

    local j=1
    declare -a sel_fmt_ids=()
    for fline in "${fmt_lines[@]}"; do
        local fid fps_val clabel ckey cont
        IFS='|' read -r fid fps_val clabel ckey cont <<< "$fline"

        local codec_icono="${C}🎬${NC}"
        [[ "$ckey" == "av1_hdr" || "$ckey" == "vp9_hdr" ]] && codec_icono="${Y}✨${NC}"

        echo -e "  ${W}${j}.${NC} ${codec_icono}  ${clabel}  ${DIM}${fps_val}fps | ${cont}${NC}"
        sel_fmt_ids+=("${fid}|${cont}")
        ((j++))
    done
    echo -e "  ${W}${j}.${NC} ${R}✖${NC}  Cancelar"
    linea
    while true; do
        echo -ne "${Y}  ➜  Opcion: ${NC}"
        read -r codec_choice

        if [[ "$codec_choice" == "$j" ]] || [[ -z "$codec_choice" ]]; then
            menu_principal; return
        fi

        if ! [[ "$codec_choice" =~ ^[0-9]+$ ]] || (( codec_choice < 1 || codec_choice >= j )); then
            warn "Opcion invalida"
            continue
        fi

        break
    done

    local sel_entry="${sel_fmt_ids[$((codec_choice - 1))]}"
    local sel_fmt="${sel_entry%%|*}"
    local sel_container="${sel_entry##*|}"

    # ── Descarga: video elegido + 140 (m4a 129k mejor audio YT) ────
    echo
    linea
    info "Descargando ${res_names[$sel_height]} + audio 140 (m4a 129k)..."
    echo -e "  ${DIM}Formato video: ${sel_fmt}   Audio: 140${NC}"
    linea

    if yt-dlp -f "${sel_fmt}+140" \
              --merge-output-format "$sel_container" \
              --restrict-filenames \
              --output "%(title).50s.%(ext)s" \
              "$url"; then
        echo; linea
        ok "¡Descarga completada! 🎉"
        linea
        menu_conversion
    else
        echo; err "Error durante la descarga"
    fi

    echo -ne "${DIM}  Presiona Enter...${NC}"; read -r
    menu_principal
}

# ====================================================================
# Facebook — URL con reintento + opcion de audio m4a
# ====================================================================
descargar_facebook() {
    clear
    linea
    echo -e "  ⬇️   Descargando de ${B}f  Facebook${NC}"
    linea

    local url="" tmp_formats

    echo
    echo -ne "${Y}  🔗  Pega la URL del video: ${NC}"
    read -r url

    if [[ -z "$url" ]]; then
        err "No has ingresado ninguna URL"
        echo -ne "${DIM}  Presiona Enter...${NC}"; read -r
        menu_principal; return
    fi

    url="${url%%\?*}"
    tmp_formats=$(mktemp /tmp/vget_formats.XXXXXX)

    echo
    info "URL: ${W}$url${NC}"
    echo
    info "Obteniendo informacion del video..."
    linea

    if ! yt-dlp -F "$url" > "$tmp_formats" 2>&1; then
        cat "$tmp_formats"
        rm -f "$tmp_formats"
        echo
        err "URL invalida o no se pudo obtener informacion"
        echo -ne "${DIM}  Presiona Enter...${NC}"; read -r
        menu_principal; return
    fi
    cat "$tmp_formats"

    # Parsear IDs: audio m4a_dash y ultimo video mp4_dash
    local audio_id video_id
    audio_id=$(grep 'm4a_dash' "$tmp_formats" | awk '{print $1}' | head -1)
    video_id=$(grep 'mp4_dash' "$tmp_formats" | grep 'video only' | tail -1 | awk '{print $1}')
    rm -f "$tmp_formats"

    echo
    if [[ -n "$audio_id" && -n "$video_id" ]]; then
        info "Formato video: ${W}${video_id}${NC}  Audio: ${W}${audio_id}${NC}"
    else
        warn "No se encontraron formatos DASH, usando mejor calidad disponible..."
        audio_id="bestaudio[ext=m4a]/bestaudio"
        video_id="bestvideo"
    fi
    linea

    if yt-dlp -f "${video_id}+${audio_id}" \
              --merge-output-format mp4 \
              --restrict-filenames --output "%(title).50s.%(ext)s" "$url"; then
        echo; linea
        ok "¡Descarga completada! 🎉"
        linea
        menu_conversion
    else
        err "Error durante la descarga"
    fi

    echo
    linea
    echo -ne "${DIM}  Presiona Enter para continuar...${NC}"
    read -r
    menu_principal
}

# ====================================================================
# Instagram — con cookies de navegador
# ====================================================================
descargar_instagram() {
    clear
    linea
    echo -e "  ⬇️   Descargando de ${M}📷  Instagram${NC}"
    linea
    # Detectar navegador disponible (chrome > firefox > brave)
    local browser=""
    if command -v chrome &>/dev/null || command -v google-chrome &>/dev/null || command -v google-chrome-stable &>/dev/null; then
        browser="chrome"
    elif command -v firefox &>/dev/null; then
        browser="firefox"
    elif command -v brave &>/dev/null || command -v brave-browser &>/dev/null; then
        browser="brave"
    fi

    if [[ -z "$browser" ]]; then
        echo
        err "No se encontro ningun navegador soportado (Chrome, Firefox, Brave)"
        err "Instala uno de esos navegadores para descargar de Instagram"
        echo -ne "${DIM}  Presiona Enter...${NC}"; read -r
        menu_principal; return
    fi

    info "Navegador detectado: ${W}${browser}${NC}"

    local url=""
    echo
    echo -ne "${Y}  🔗  Pega la URL del video: ${NC}"
    read -r url

    if [[ -z "$url" ]]; then
        err "No has ingresado ninguna URL"
        echo -ne "${DIM}  Presiona Enter...${NC}"; read -r
        menu_principal; return
    fi

    # Extraer solo la URL base del post: https://www.instagram.com/p/SHORTCODE/
    if [[ "$url" =~ (https://www\.instagram\.com/p/[^/?]+/) ]]; then
        url="${BASH_REMATCH[1]}"
    else
        url="${url%%\?*}"
    fi

    echo
    info "URL: ${W}$url${NC}"
    echo
    info "Verificando URL..."
    linea

    if ! yt-dlp --cookies-from-browser "$browser" \
                --flat-playlist --print id \
                --playlist-items 1 --quiet "$url" 2>/dev/null; then
        echo
        err "URL invalida o no se pudo obtener informacion"
        echo -ne "${DIM}  Presiona Enter...${NC}"; read -r
        menu_principal; return
    fi

    echo
    info "Descargando con cookies de ${W}${browser}${NC}..."
    info "Formato: mejor video mp4_dash + audio m4a (con fallback automatico)"
    linea

    # Registrar archivos existentes antes de descargar
    local before=()
    mapfile -t before < <(ls ./*.mp4 2>/dev/null || true)

    yt-dlp --cookies-from-browser "$browser" \
           -f "bestvideo[ext=mp4]+bestaudio[ext=m4a]/bestvideo[ext=mp4]+bestaudio/bestvideo+bestaudio/best" \
           --merge-output-format mp4 \
           --yes-playlist --ignore-errors \
           --restrict-filenames --output "%(playlist_index)02d-%(title).50s.%(ext)s" "$url" || true

    # Detectar archivos nuevos o modificados comparando con antes
    _DL_FILES=()
    for f in ./*.mp4; do
        [[ -f "$f" ]] || continue
        local found=0
        for ef in "${before[@]}"; do
            [[ "$f" == "$ef" ]] && found=1 && break
        done
        (( found == 0 )) && _DL_FILES+=("$f")
    done
    # Si ya existian (re-descarga), incluirlos igual
    if [[ ${#_DL_FILES[@]} -eq 0 ]]; then
        mapfile -t _DL_FILES < <(ls ./*.mp4 2>/dev/null | head -20 || true)
    fi

    echo; linea
    ok "¡Descarga completada! 🎉"
    linea
    menu_conversion

    echo
    linea
    echo -ne "${DIM}  Presiona Enter para continuar...${NC}"
    read -r
    menu_principal
}

# ====================================================================
# TikTok / Facebook / Instagram — descarga genérica
# ====================================================================
descargar() {
    local plataforma="$1"
    local label="$2"

    clear
    linea
    echo -e "  ⬇️   Descargando de ${label}"
    linea
    echo
    echo -ne "${Y}  🔗  Pega la URL del video: ${NC}"
    read -r url

    if [[ -z "$url" ]]; then
        err "No has ingresado ninguna URL"
        echo -ne "${DIM}  Presiona Enter para continuar...${NC}"
        read -r
        menu_principal
        return
    fi

    url="${url%%\?*}"

    echo
    info "URL: ${W}$url${NC}"
    echo
    info "Obteniendo informacion del video..."
    linea

    local tmp_formats; tmp_formats=$(mktemp /tmp/vget_formats.XXXXXX)
    yt-dlp -F "$url" > "$tmp_formats" 2>&1
    cat "$tmp_formats"

    echo
    linea
    info "Seleccionando mejor formato disponible..."

    local best_format=""
    while IFS= read -r line; do
        local first_word="${line%% *}"
        if [[ -n "$first_word" && "$first_word" != "ID" && "$first_word" != "---"* && "$first_word" != "Available" && "$first_word" != "download" ]]; then
            best_format="$first_word"
        fi
    done < "$tmp_formats"
    rm -f "$tmp_formats"

    echo
    if [[ -z "$best_format" ]]; then
        warn "No se encontro formato especifico, usando mejor calidad disponible..."
        yt-dlp -f "best" --restrict-filenames --output "%(title).50s.%(ext)s" "$url"
    else
        ok "Formato seleccionado: ${W}$best_format${NC}"
        echo -e "  ${DIM}Comando: yt-dlp -f \"$best_format\" --restrict-filenames -o \"%(title).50s.%(ext)s\" \"$url\"${NC}"
        linea
        if yt-dlp -f "$best_format" --restrict-filenames --output "%(title).50s.%(ext)s" "$url"; then
            echo; linea
            ok "¡Descarga completada! 🎉"
            linea
            menu_conversion
        fi
    fi

    echo
    linea
    echo -ne "${DIM}  Presiona Enter para continuar...${NC}"
    read -r
    menu_principal
}

# ====================================================================
# Conversión de audio a MP3 (video stream copiado sin recodificar)
# ====================================================================
menu_conversion() {
    while true; do
        echo
        linea
        echo -e "  ${C}¿Quieres convertir video con audio MP3?${NC}"
        echo -e "  ${DIM}(Funciona bien para Resolve — solo convierte el audio, reserva el el codec de video)${NC}"
        echo
        echo -e "  ${W}1.${NC} ${G}✔${NC}  Si — libmp3lame (rapido)"
        echo -e "  ${W}2.${NC} ${Y}✖${NC}  No — mantener audio original"
        echo
        echo -ne "${Y}  ➜  Selecciona una opcion (1-2): ${NC}"
        read -r conv_opcion

        case "$conv_opcion" in
            1)
                echo; linea
                info "Iniciando conversion de audio... ⚙️"
                linea
                convert_video
                return
                ;;
            2)
                echo; ok "Audio mantenido en formato original."
                return
                ;;
            *)
                warn "Opcion no valida, intenta de nuevo."
                ;;
        esac
    done
}

_convert_one() {
    local video_file="$1"
    local temp_converted="${video_file%.mp4}_temp_converted.mp4"

    info "Convirtiendo: ${W}${video_file}${NC}"
    linea

    if ffmpeg -i "$video_file" -c:v copy -c:a libmp3lame "$temp_converted" -y; then
        echo; linea
        if rm "$video_file" && mv "$temp_converted" "$video_file"; then
            ok "Guardado: ${W}$video_file${NC} ✅"
        else
            err "Error al reemplazar: $video_file"
        fi
        linea
    else
        echo; linea
        err "Error convirtiendo: $video_file"
        warn "Verifica que ffmpeg este instalado: ${DIM}pacman -S ffmpeg${NC}"
        linea
        rm -f "$temp_converted"
    fi
}

convert_video() {
    # Instagram: convertir todos los archivos descargados
    if [[ ${#_DL_FILES[@]} -gt 0 ]]; then
        local files=("${_DL_FILES[@]}")
        _DL_FILES=()

        local total=${#files[@]}
        info "Videos a convertir: ${W}${total}${NC}"
        linea

        local current=0
        for video_file in "${files[@]}"; do
            current=$(( current + 1 ))
            echo
            info "[${current}/${total}]"
            _convert_one "$video_file"
        done

        echo
        ok "Conversion completada: ${W}${current}/${total}${NC} archivos"

    # Otros: convertir solo el ultimo .mp4
    else
        info "Buscando video descargado..."

        local video_file; video_file=$(ls -t ./*.mp4 2>/dev/null | head -n1 || true)

        if [[ -z "$video_file" ]]; then
            err "No se encontro archivo .mp4 en el directorio actual"
            return
        fi

        echo
        _convert_one "$video_file"
    fi
}

salir() {
    clear
    echo
    echo -e "${M}  ¡Hasta luego!${NC}"
    echo
    sleep 1
    exit 0
}

# ====================================================================
# Verificar e instalar dependencias
# ====================================================================
verificar_dependencias() {
    local pkgs=(yt-dlp ffmpeg rtmpdump atomicparsley aria2
                python-curl_cffi python-mutagen python-pycryptodome
                python-websockets python-brotli python-xattr
                python-secretstorage)
    local faltantes=()

    clear
    box_top
    brow "  Verificando dependencias...  " "  ${W}Verificando dependencias...${NC}  "
    box_bot
    echo

    for pkg in "${pkgs[@]}"; do
        if pacman -Q "$pkg" &>/dev/null; then
            ok "$pkg"
        else
            warn "$pkg  (no instalado)"
            faltantes+=("$pkg")
        fi
    done

    if [[ ${#faltantes[@]} -gt 0 ]]; then
        echo
        info "Instalando paquetes faltantes: ${faltantes[*]}"
        sudo pacman -Sy --noconfirm "${faltantes[@]}"
    fi

    echo
    info "Verificando actualizaciones de yt-dlp..."
    yt-dlp -U
    echo
    sleep 2
}

verificar_dependencias
menu_principal
